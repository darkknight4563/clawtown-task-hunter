# ── Frontend (Vite) ────────────────────────────────────────────────
# Copy this file to .env.local and fill in your own values.
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=https://your-app.base44.app

# ── Backend functions (Base44 / Deno) ──────────────────────────────
# Set these in the Base44 function environment, NOT in the frontend bundle.
BASE44_APP_ID=your_app_id
BASE44_SERVICE_TOKEN=your_service_role_token

# Slack integration (optional)
SLACKBOT_ACCESS_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
